{
  "version": 2,
  "framework": "create-react-app",
  "installCommand": "npm install --prefix client",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/build",
  "redirects": [
    {
      "source": "/(.*)/",
      "destination": "/$1",
      "statusCode": 308
    },
    {
      "source": "/professionals",
      "destination": "/premarital-counseling",
      "statusCode": 301
    },
    {
      "source": "/professionals/:path*",
      "destination": "/premarital-counseling/:path*",
      "statusCode": 301
    },
    {
      "source": "/states",
      "destination": "/premarital-counseling",
      "statusCode": 301
    },
    {
      "source": "/states/:path*",
      "destination": "/premarital-counseling/:path*",
      "statusCode": 301
    },
    {
      "source": "/therapists",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/coaches",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/clergy",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/find-counselor",
      "destination": "/premarital-counseling",
      "statusCode": 301
    },
    {
      "source": "/find-counselors",
      "destination": "/premarital-counseling",
      "statusCode": 301
    },
    {
      "source": "/counselors",
      "destination": "/premarital-counseling",
      "statusCode": 301
    },
    {
      "source": "/pre-cana",
      "destination": "/premarital-counseling/catholic",
      "statusCode": 301
    },
    {
      "source": "/pre-cana/:path*",
      "destination": "/premarital-counseling/catholic",
      "statusCode": 301
    },
    {
      "source": "/professionals-list",
      "destination": "/premarital-counseling",
      "statusCode": 301
    },
    {
      "source": "/blog/financial-questions-before-marriage",
      "destination": "/blog/financial-questions-to-ask-before-marriage",
      "statusCode": 301
    },
    {
      "source": "/blog/wedding-planning-fights",
      "destination": "/blog/fighting-about-wedding-planning",
      "statusCode": 301
    },
    {
      "source": "/blog/inlaw-boundaries",
      "destination": "/blog/setting-healthy-boundaries-with-inlaws",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/api/unsubscribe",
      "destination": "https://bkjwctlolhoxhnoospwp.supabase.co/functions/v1/unsubscribe-digest"
    },
    {
      "source": "/auth/v1/:path*",
      "destination": "https://bkjwctlolhoxhnoospwp.supabase.co/auth/v1/:path*"
    },
    {
      "source": "/premarital-counseling/:state/:city/:slug",
      "destination": "/api/seo-profile-renderer"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}