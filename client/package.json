{
  "name": "premarital-counseling-directory",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@stripe/react-stripe-js": "^2.3.1",
    "@stripe/stripe-js": "^2.1.7",
    "@supabase/supabase-js": "^2.38.4",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.8.1",
    "react-scripts": "5.0.1",
    "recharts": "^2.8.0",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^3.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "react-scripts build",
    "postbuild": "node scripts/prerender.js",
    "build:sitemap": "node scripts/generate-sitemap.js",
    "validate:seo": "node scripts/validate-seo.mjs",
    "audit:contrast": "node scripts/a11y-contrast-audit.js",
    "audit:contrast:full": "node scripts/a11y-contrast-audit.js --full",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "npm start",
    "build:prod": "npm run build",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "analyze": "npm run build && npx source-map-explorer 'build/static/js/*.js'",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint src --ext .js,.jsx --no-eslintrc --config eslint.lint.json",
    "snapshot": "node scripts/visual-snapshot.js",
    "prepare": "cd .. && husky client/.husky"
  },
  "lint-staged": {
    "src/**/*.css": "stylelint",
    "src/**/*.{js,jsx}": "eslint --no-eslintrc --config eslint.lint.json"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "puppeteer": "^24.37.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
